SELECT
T0.DocEntry,
T0.DocNum,
T0.ObjType,
T0.DocDate,
T0.DocDueDate,
T5.SlpName,
T2.CardCode,
T2.CardName,
ISNULL(T6.TaxId0, T6.TaxId4) AS [CPF/CNPJ],
T6.TaxId1,
T6.AddrTypeS,
T6.StreetS,
T6.StreetNoS,
T6.BlockS,
T6.CityS,
T6.StateS,
T6.ZipCodeS,
T3.Name,
T2.Phone1,
T2.Phone2,
T7.ItemCode,
T7.ItemName,
T1.Quantity,
T7.BuyUnitMsr,
T7.SalUnitMsr,
T1.Price,
T1.LineTotal,
T7.UserText,
T4.PymntGroup,
T1.LineNum,
T0.TrnspCode,
T16.TrnspName AS TipoFrete,
T0.Weight,
T2.Cellular,
T2.E_Mail,
ISNULL(T13.LineTotal, 0) AS Frete,
ISNULL(T18.LineTotal, 0) AS Juros,
T0.DiscSum,
T0.DiscPrcnt,
T0.Comments,
T0.BplId,
T6.Carrier,
T14.CardName AS CarrierName,
T15.[Usage],
T0.DocTotal,
T0.VatSum
FROM ORDR T0
INNER JOIN RDR1 T1
ON T0.DocEntry = T1.DocEntry
INNER JOIN OCRD T2
ON T0.CardCode = T2.CardCode
LEFT JOIN OCPR T3
ON T0.CntctCode = T3.CntctCode
LEFT JOIN OCTG T4
ON T0.GroupNum = T4.GroupNum
INNER JOIN OSLP T5
ON T0.SlpCode = T5.SlpCode
INNER JOIN RDR12 T6
ON T0.DocEntry = T6.DocEntry
INNER JOIN OITM T7
ON T1.ItemCode = T7.ItemCode
LEFT JOIN RDR3 T13
ON T0.DocEntry = T13.DocEntry
AND T13.ExpnsCode = 3
LEFT JOIN OCRD T14
ON T6.Carrier = T14.CardCode
LEFT JOIN OUSG T15
ON T6.MainUsage = T15.ID
LEFT JOIN OSHP T16
ON T0.TrnspCode = T16.TrnspCode
LEFT JOIN RDR3 T18
ON T0.DocEntry = T18.DocEntry
AND T18.ExpnsCode = 11
WHERE
T0.DocEntry = {?DocKey@}
AND T0.ObjType = {?ObjectId@}
AND T1.TreeType <> 'I'
ORDER BY
T1.LineNum

